# Discord
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_ALLOWED_ROLE_IDS=
DISCORD_ADMIN_USER_IDS=

# Database
DATABASE_URL=postgresql+asyncpg://hlagent:hlagent@postgres:5432/hlagent
POSTGRES_USER=hlagent
POSTGRES_PASSWORD=hlagent
POSTGRES_DB=hlagent

# LLM provider chain. At least one corresponding key should be set.
# Supported chain entries:
# - openrouter:<provider/model-slug>, e.g. openrouter:anthropic/claude-sonnet-4.6
# - openai:<model-name>, e.g. openai:gpt-4o or openai:gpt-4o-mini
# - anthropic:<model-name>, e.g. anthropic:claude-3-5-haiku-latest
# - kimi:<moonshot-model-name>, e.g. kimi:moonshot-v1-8k or kimi:kimi-k2.6
# Development default: free OpenRouter models only.
AGENT_MODEL_CHAIN=openrouter:deepseek/deepseek-v4-flash,openrouter:xiaomi/mimo-v2.5,openrouter:deepseek/deepseek-v4-pro
# Example mixed personal paid-provider fallback chain:
# AGENT_MODEL_CHAIN=openrouter:anthropic/claude-sonnet-4.6,openai:gpt-4o,kimi:kimi-k2.6
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Kimi Platform / Moonshot API keys use https://api.moonshot.ai/v1 and can serve kimi:kimi-k2.6.
# Kimi Code Console keys use https://api.kimi.com/coding/v1 and expose kimi-for-coding,
# but that endpoint currently rejects non-coding-agent chat/completions, so do not add it
# to AGENT_MODEL_CHAIN for this trading bot unless Kimi changes the access policy.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# High-stakes multi-agent debate (proposal/paper only; no signed execution)
HIGH_STAKES_DEBATE_ENABLED=false
HIGH_STAKES_ACTIVATION_POLICY=risk_routed
HIGH_STAKES_PROMPT_STYLE=aggressive
HIGH_STAKES_INFO_PROVIDER=sdk_preferred
# Per-role leash = (TIMEOUT_SECONDS - reserve - elapsed) / sequential phases, and each
# role's fallback chain gets a per-attempt slice of that leash. MAX_ROUNDS bounds debate
# revisions but no longer divides the per-call budget, so raising it does not starve calls.
HIGH_STAKES_MAX_ROUNDS=3
HIGH_STAKES_TIMEOUT_SECONDS=180
HIGH_STAKES_REVIEW_CONCURRENCY=3
HIGH_STAKES_MAX_COINS=3
HIGH_STAKES_MAX_DATA_ESCALATIONS=1
HIGH_STAKES_REQUIRE_ACCOUNT_FOR_AUTONOMOUS=false
DEBATE_MODEL_DIVERSITY_POLICY=warn
ACCOUNT_ADDRESS_ALLOWLIST=
HIGH_STAKES_SMART_MONEY_ADDRESSES=
AGENT_API_BEARER_TOKEN=
# Paid model grid (June 2026). The decision spine (analyst -> adversary -> judge) uses
# three distinct frontier labs (Qwen3.7-Max -> Gemini-3.1-Pro -> Claude Opus 4.8); the
# analyst is distinct from every reviewer (no reviewer grades its own draft) and quant
# != risk. Cheap strong reasoners (DeepSeek V4 Flash, Ring-2.6-1T, MiMo) run the parallel
# reviewers; fallbacks are reliable paid LLMs so a role reaches a real model before the
# deterministic last resort. Judge alternatives worth trying: anthropic/claude-sonnet-4.6
# (finance-bench leader, cheaper) or openrouter/fusion (ensemble of frontier models).
DEBATE_ANALYST_MODEL_CHAIN=openrouter:qwen/qwen3.7-max,openrouter:deepseek/deepseek-v4-pro,openrouter:xiaomi/mimo-v2.5
DEBATE_QUANT_MODEL_CHAIN=openrouter:deepseek/deepseek-v4-pro,openrouter:deepseek/deepseek-v4-flash,openrouter:inclusionai/ring-2.6-1t
DEBATE_RESEARCH_MODEL_CHAIN=openrouter:xiaomi/mimo-v2.5,openrouter:deepseek/deepseek-v4-flash,openrouter:minimax/minimax-m3
DEBATE_RISK_MODEL_CHAIN=openrouter:inclusionai/ring-2.6-1t,openrouter:deepseek/deepseek-v4-flash,openrouter:xiaomi/mimo-v2.5
DEBATE_TREASURY_MODEL_CHAIN=openrouter:deepseek/deepseek-v4-flash,openrouter:xiaomi/mimo-v2.5
DEBATE_EXECUTION_MODEL_CHAIN=openrouter:deepseek/deepseek-v4-flash,openrouter:xiaomi/mimo-v2.5,openrouter:minimax/minimax-m3
DEBATE_ADVERSARY_MODEL_CHAIN=openrouter:google/gemini-3.1-pro-preview,openrouter:x-ai/grok-4.3,openrouter:deepseek/deepseek-v4-pro
DEBATE_JUDGE_MODEL_CHAIN=openrouter:anthropic/claude-opus-4.8,openrouter:anthropic/claude-sonnet-4.6,openrouter:deepseek/deepseek-v4-pro

# Hyperliquid
HYPERLIQUID_NETWORK=mainnet
