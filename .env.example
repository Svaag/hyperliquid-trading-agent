# Discord
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_ALLOWED_ROLE_IDS=
DISCORD_ADMIN_USER_IDS=

# Database
DATABASE_URL=postgresql+asyncpg://hlagent:hlagent@postgres:5432/hlagent
POSTGRES_USER=hlagent
POSTGRES_PASSWORD=hlagent
POSTGRES_DB=hlagent

# LLM provider chain. At least one corresponding key should be set.
# Supported chain entries:
# - openrouter:<provider/model-slug>, e.g. openrouter:anthropic/claude-sonnet-4.6
# - openai:<model-name>, e.g. openai:gpt-4o or openai:gpt-4o-mini
# - anthropic:<model-name>, e.g. anthropic:claude-3-5-haiku-latest
# - kimi:<moonshot-model-name>, e.g. kimi:moonshot-v1-8k or kimi:kimi-k2.6
# Development default: free OpenRouter models only.
AGENT_MODEL_CHAIN=openrouter:openai/gpt-oss-120b:free,openrouter:openai/gpt-oss-20b:free,openrouter:liquid/lfm-2.5-1.2b-instruct:free,openrouter:nvidia/nemotron-3-nano-30b-a3b:free
# Example mixed personal paid-provider fallback chain:
# AGENT_MODEL_CHAIN=openrouter:anthropic/claude-sonnet-4.6,openai:gpt-4o,kimi:kimi-k2.6
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Kimi Platform / Moonshot API keys use https://api.moonshot.ai/v1 and can serve kimi:kimi-k2.6.
# Kimi Code Console keys use https://api.kimi.com/coding/v1 and expose kimi-for-coding,
# but that endpoint currently rejects non-coding-agent chat/completions, so do not add it
# to AGENT_MODEL_CHAIN for this trading bot unless Kimi changes the access policy.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# High-stakes multi-agent debate (proposal/paper only; no signed execution)
HIGH_STAKES_DEBATE_ENABLED=false
HIGH_STAKES_ACTIVATION_POLICY=risk_routed
HIGH_STAKES_PROMPT_STYLE=aggressive
HIGH_STAKES_INFO_PROVIDER=sdk_preferred
HIGH_STAKES_MAX_ROUNDS=3
HIGH_STAKES_TIMEOUT_SECONDS=180
HIGH_STAKES_REVIEW_CONCURRENCY=3
HIGH_STAKES_MAX_COINS=3
HIGH_STAKES_MAX_DATA_ESCALATIONS=1
HIGH_STAKES_REQUIRE_ACCOUNT_FOR_AUTONOMOUS=false
DEBATE_MODEL_DIVERSITY_POLICY=warn
ACCOUNT_ADDRESS_ALLOWLIST=
HIGH_STAKES_SMART_MONEY_ADDRESSES=
AGENT_API_BEARER_TOKEN=
# Role-specific primary models should differ. Judge should be your strongest/main model in production.
# These development defaults use free OpenRouter models and may be rate-limited; replace Judge with a frontier model when available.
DEBATE_ANALYST_MODEL_CHAIN=openrouter:qwen/qwen3-next-80b-a3b-instruct:free,openrouter:openai/gpt-oss-120b:free,openrouter:nex-agi/nex-n2-pro:free
DEBATE_QUANT_MODEL_CHAIN=openrouter:nvidia/nemotron-3-nano-30b-a3b:free,openrouter:openai/gpt-oss-20b:free,openrouter:nex-agi/nex-n2-pro:free
DEBATE_RESEARCH_MODEL_CHAIN=openrouter:google/gemma-4-26b-a4b-it:free,openrouter:openai/gpt-oss-20b:free,openrouter:nex-agi/nex-n2-pro:free
DEBATE_ADVERSARY_MODEL_CHAIN=openrouter:meta-llama/llama-3.3-70b-instruct:free,openrouter:openai/gpt-oss-120b:free,openrouter:nex-agi/nex-n2-pro:free
DEBATE_RISK_MODEL_CHAIN=openrouter:openai/gpt-oss-20b:free,openrouter:nvidia/nemotron-3-nano-30b-a3b:free,openrouter:nex-agi/nex-n2-pro:free
DEBATE_TREASURY_MODEL_CHAIN=openrouter:liquid/lfm-2.5-1.2b-instruct:free,openrouter:openai/gpt-oss-20b:free,openrouter:nex-agi/nex-n2-pro:free
DEBATE_EXECUTION_MODEL_CHAIN=openrouter:nex-agi/nex-n2-pro:free,openrouter:liquid/lfm-2.5-1.2b-instruct:free,openrouter:openai/gpt-oss-20b:free
DEBATE_JUDGE_MODEL_CHAIN=openrouter:openai/gpt-oss-120b:free,openrouter:openai/gpt-oss-20b:free,openrouter:nex-agi/nex-n2-pro:free

# Hyperliquid
HYPERLIQUID_NETWORK=mainnet
HYPERLIQUID_MAINNET_URL=https://api.hyperliquid.xyz
HYPERLIQUID_TESTNET_URL=https://api.hyperliquid-testnet.xyz
HYPERLIQUID_MAINNET_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_TESTNET_WS_URL=wss://api.hyperliquid-testnet.xyz/ws
HYPERLIQUID_WS_ENABLED=false
HYPERLIQUID_EXCHANGE_ENABLED=false

# Live position tracking / websocket level alerts (no LLMs, no execution)
POSITION_TRACKING_ENABLED=true
POSITION_TRACKING_AUTO_ARM=true
POSITION_TRACKING_DEFAULT_TTL_HOURS=168
POSITION_TRACKING_PRICE_SOURCE=allMids
POSITION_TRACKING_REARM_BAND_BPS=10
POSITION_TRACKING_RELOAD_SECONDS=10
POSITION_TRACKING_MAX_ACTIVE=250
POSITION_TRACKING_ALERT_RETRY_COUNT=3

# News/search providers
NEWS_RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://www.federalreserve.gov/feeds/press_all.xml
TAVILY_API_KEY=
SERPAPI_API_KEY=
NEWSAPI_API_KEY=
PERPLEXITY_API_KEY=
X_BEARER_TOKEN=

# Ops
ENVIRONMENT=prod
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
# Host-side HTTP port for Docker Compose. Change if another local service uses 8080.
HOST_PORT=8081
PUBLIC_HOSTNAME=
METRICS_BEARER_TOKEN=
CACHE_TTL_MARKET_SECONDS=15
CACHE_TTL_NEWS_SECONDS=600
